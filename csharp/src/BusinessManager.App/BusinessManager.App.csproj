<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0-android;net8.0-windows10.0.19041.0</TargetFrameworks>
    <OutputType>Exe</OutputType>
    <UseMaui>true</UseMaui>
    <SingleProject>true</SingleProject>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <ApplicationTitle>BusinessManager</ApplicationTitle>
    <ApplicationId>com.company.businessmanager</ApplicationId>
    <ApplicationDisplayVersion>0.1.0</ApplicationDisplayVersion>
    <ApplicationVersion>1</ApplicationVersion>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\BusinessManager.Core\BusinessManager.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <MauiAsset Include="..\..\data\mvp_scenario.json" LogicalName="mvp_scenario.json" />
  </ItemGroup>

</Project>
